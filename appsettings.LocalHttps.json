{
  "AbuseCounterBundleSettings": {
    "servers": "localhost",
    "port": 6379,
    "database": 2,
    "clientName": "treehammock-api-abuse-counters",
    "allowAdmin": false,
    "reconnectRetryPolicy": 5000,
    "abortOnConnectFail": false,
    "password": "",
    "connectTimeoutMilliseconds": 1000,
    "asyncTimeoutMilliseconds": 1000,
    "syncTimeoutMilliseconds": 1000,
    "connectRetry": 1
  },
  "HostingSettings": {
    "ConfigureKestrel": true,
    "Port": 5001,
    "BindAddress": "0.0.0.0",
    "UseHttps": true,
    "Protocols": "Http1AndHttp2AndHttp3",
    "UseHttpsRedirection": true,
    "UseForwardedHeaders": false,
    "ForwardLimit": 1,
    "RequireHeaderSymmetry": true,
    "TrustAllForwardedHeaderProxies": false,
    "KnownProxies": [],
    "KnownNetworks": []
  }
}
