meta {
  name: Health ready
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/health/ready
  body: none
  auth: none
}

tests {
  test("ready endpoint returns HTTP 200", function () {
    expect(res.getStatus()).to.equal(200);
  });

  test("ready endpoint reports ready status", function () {
    const body = res.getBody();
    expect(body).to.have.property("status");
    expect(body.status).to.equal("ready");
  });
}
